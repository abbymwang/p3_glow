const int NUM_SPRITES = 45;

// ── Sprite name → index lookup ───────────────────────────────────────────────
int spriteIndexByName(const char* name) {
  for (int i = 0; i < NUM_SPRITES; i++) {
    if (strcasecmp(spriteNames[i], name) == 0) return i;
  }
  return -1;
}

