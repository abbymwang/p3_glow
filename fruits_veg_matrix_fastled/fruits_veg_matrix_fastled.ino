// ── Fisher-Yates shuffle ─────────────────────────────────────────────────────
void shuffleArray(int* arr, int n) {
  for (int i = n - 1; i > 0; i--) {
    int j = random(0, i + 1);
    int tmp = arr[i];
    arr[i] = arr[j];
    arr[j] = tmp;
  }
}

// ── Build shuffled sprite list for a given month ─────────────────────────────
int buildMonthList(const char** names, int nameCount, int* outIndices) {
  int count = 0;
  for (int i = 0; i < nameCount; i++) {
    int idx = spriteIndexByName(names[i]);
    if (idx >= 0) outIndices[count++] = idx;
  }
  shuffleArray(outIndices, count);
  return count;
}

// ── Parse month from "YYYY-MM-DD" Serial input ───────────────────────────────
int parseMonthFromSerial(const String& input) {
  if (input.length() < 7) return -1;
  int month = input.substring(5, 7).toInt();
  if (month < 1 || month > 12) return -1;
  return month;
}

// ── Display one sprite using FastLED + XY mapping ────────────────────────────
void displaySprite(int index) {
  for (int row = 0; row < 8; row++) {
    for (int col = 0; col < 8; col++) {
      uint32_t color = pgm_read_dword(&sprites[index][row][col]);
      uint8_t r = (color >> 16) & 0xFF;
      uint8_t g = (color >>  8) & 0xFF;
      uint8_t b =  color        & 0xFF;
      int idx = XY(col, row);  // col=x, row=y
      if (idx >= 0) leds[idx] = CRGB(r, g, b);
    }
  }
  FastLED.show();
  Serial.print("Displaying: ");
  Serial.println(spriteNames[index]);
}

// ── Global state ─────────────────────────────────────────────────────────────
int  monthSpriteIndices[45];
int  monthSpriteCount  = 0;
int  currentSlot       = 0;
int  currentMonth      = 0;

unsigned long lastDisplayTime = 0;

// ── Load sprites for a given month ───────────────────────────────────────────
void loadMonth(int month) {
  const char** names = nullptr;
  int count = 0;
  switch (month) {
    case  1: names = JAN;     count = JAN_COUNT;     break;
    case  2: names = FEB;     count = FEB_COUNT;     break;
    case  3: names = MAR;     count = MAR_COUNT;     break;
    case  4: names = APR;     count = APR_COUNT;     break;
    case  5: names = MAY;     count = MAY_COUNT;     break;
    case  6: names = JUN;     count = JUN_COUNT;     break;
    case  7: names = JUL;     count = JUL_COUNT;     break;
    case  8: names = AUG;     count = AUG_COUNT;     break;
    case  9: names = SEP;     count = SEP_COUNT;     break;
    case 10: names = MON_OCT; count = MON_OCT_COUNT; break;
    case 11: names = NOV;     count = NOV_COUNT;     break;
    case 12: names = MON_DEC; count = MON_DEC_COUNT; break;
  }
  if (!names) return;
  monthSpriteCount = buildMonthList(names, count, monthSpriteIndices);
  currentSlot = 0;
  lastDisplayTime = millis();
  Serial.print(F("Loaded "));
  Serial.print(monthSpriteCount);
  Serial.println(F(" sprites for that month. Starting slideshow..."));
}

// ── setup ────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(9600);
  randomSeed(analogRead(A0));

  FastLED.addLeds<LED_TYPE, DATA_PIN, COLOR_ORDER>(leds, NUM_LEDS);
  FastLED.setBrightness(BRIGHTNESS);
  fill_solid(leds, NUM_LEDS, CRGB::Black);
  FastLED.show();

  Serial.println(F("READY"));
}

// ── loop ─────────────────────────────────────────────────────────────────────
void loop() {
  // Check for new date input over Serial
  if (Serial.available()) {
    String input = Serial.readStringUntil('\n');
    input.trim();
    int month = parseMonthFromSerial(input);
    if (month > 0) {
      currentMonth = month;
      loadMonth(currentMonth);
      if (monthSpriteCount > 0) displaySprite(monthSpriteIndices[currentSlot]);
    }
  }

  // Advance slideshow on timer
  if (currentMonth > 0 && monthSpriteCount > 0) {
    unsigned long now = millis();
    if (now - lastDisplayTime >= DISPLAY_DURATION) {
      lastDisplayTime = now;
      currentSlot++;
      if (currentSlot >= monthSpriteCount) {
        currentSlot = 0;
        shuffleArray(monthSpriteIndices, monthSpriteCount);
        Serial.println(F("--- reshuffled ---"));
      }
      displaySprite(monthSpriteIndices[currentSlot]);
    }
  }
}
